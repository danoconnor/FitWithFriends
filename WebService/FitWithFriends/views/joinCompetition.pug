extends layout

block content
  .page
    header.wordmark
      .wordmark-mark
        svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' width='14' height='14' fill='white')
          path(d='M13.5 3.5c1-1.1 2.6-1.5 3.5-1.5.2 1.6-.4 3-1.4 4.1-.9 1.1-2.4 2-3.9 1.9-.2-1.5.5-3.1 1.3-4.2zM18.7 19.5c-.8 1.2-1.7 2.5-3.1 2.5-1.3 0-1.8-.8-3.3-.8-1.5 0-2 .8-3.3.8-1.3 0-2.3-1.3-3.1-2.5-1.7-2.5-3-7 1.1-9.5 1.1-.6 2.4-.9 3.6-.9 1.2 0 2.3.8 3.1.8.7 0 2.2-.9 3.7-.7.6 0 2.4.2 3.6 1.9-.1.1-2.1 1.2-2.1 3.7 0 2.9 2.6 3.9 2.6 3.9-.1.1-.4 1.3-1.3 2.8z')
      .wordmark-name FitWithFriends
      a.skip-link(href=isIOS ? appStoreUrl : '#') Get app

    main
      span.tag You've been invited
      if inviterName
        .inviter-row
          .inviter-avatar= inviterInitials
          .inviter-text
            strong= inviterName
            |  invited you to a competition

      if competitionName
        section.hero-card
          h1.hero-name= competitionName
          .chip-row
            if visibility
              span.chip(class=visibility === 'Public' ? 'chip-public' : 'chip-private')
                if visibility === 'Public'
                  svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' width='10' height='10')
                    circle(cx='12' cy='12' r='10')
                    line(x1='2' y1='12' x2='22' y2='12')
                    path(d='M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20z')
                else
                  svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' width='10' height='10')
                    rect(x='3' y='11' width='18' height='11' rx='2' ry='2')
                    path(d='M7 11V7a5 5 0 0 1 10 0v4')
                | #{visibility}
                if memberCount > 0
                  |  · #{memberCount} member#{memberCount === 1 ? '' : 's'}
            if scoringLabel
              span.chip.chip-brand= scoringLabel
            if dateRange
              span.chip.chip-muted= dateRange

          - var palette = ['#FA114F', '#3C5BBF', '#92E82A', '#F2A03E', '#1EEAEF', '#D9A33A', '#7A5BC0', '#2A8C66']
          if members && members.length > 0
            .members-pile
              each m, i in members
                .member-avatar(style=`background:${palette[i % palette.length]}` title=m.firstName)= m.initials
              if membersExtra > 0
                .member-extra +#{membersExtra}
              span.members-label Already in the group
      else
        section.hero-card.hero-card-anonymous
          h1.hero-name You've been invited to a competition
          p.hero-sub Open the link on your iPhone to see the details and join with one tap.

      section.benefits
        .benefit
          .benefit-icon.benefit-icon-brand
            svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='18' height='18')
              circle(cx='12' cy='12' r='10')
              polyline(points='12 6 12 12 16 14')
          .benefit-text
            strong Live leaderboard
            span Updates hourly. Your row stays pinned.
        .benefit
          .benefit-icon.benefit-icon-exercise
            svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='18' height='18')
              path(d='M22 11.08V12a10 10 0 1 1-5.93-9.14')
              polyline(points='22 4 12 14.01 9 11.01')
          .benefit-text
            strong Apple Watch sync
            span Activity is pulled automatically.
        .benefit
          .benefit-icon.benefit-icon-move
            svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='18' height='18')
              path(d='M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z')
          .benefit-text
            strong Group chat energy
            span Trash talk encouraged.

      section.cta-block
        if isIOS
          a.cta-primary(href=appStoreUrl)
            svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='white' width='18' height='18')
              path(d='M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z')
            span Get FitWithFriends
          a.cta-secondary(href=appDeeplink) Already have the app? Open
        else
          .ios-banner
            strong iOS only
            span FitWithFriends is currently available on iPhone and iPad. Open this link on an iOS device to join.
            a.cta-secondary(href=appStoreUrl) View on the App Store

    footer.footer
      | Free to use · Requires Apple Watch or iPhone health data
